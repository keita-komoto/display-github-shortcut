{
  "manifest_version": 3,
  "name": "GitHub Shortcut Badges",
  "version": "1.1.0",
  "icons": {
    "16": "icons/ghsb_icon16.png",
    "32": "icons/ghsb_icon32.png",
    "48": "icons/ghsb_icon48.png",
    "128": "icons/ghsb_icon128.png"
  },
  "permissions": ["storage"],
  "host_permissions": ["https://github.com/*"],
  "content_scripts": [
    {
      "matches": ["https://github.com/*"],
      "js": ["contentScript.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "action": {
    "default_popup": "popup.html",
    "default_title": "GitHub Shortcut Badges",
    "default_icon": {
      "16": "icons/ghsb_icon16.png",
      "32": "icons/ghsb_icon32.png"
    }
  }
}
