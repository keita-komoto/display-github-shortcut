{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": ["chrome", "node"],
    "skipLibCheck": false
  },
  "include": ["src/**/*.ts", "test/**/*.ts"]
}
